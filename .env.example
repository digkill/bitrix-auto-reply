APP_PORT=8080

# Bitrix24 incoming webhook base URL.
# Required scope: im (Chat and notifications).
# Format: https://your-company.bitrix24.ru/rest/USER_ID/WEBHOOK_TOKEN/
BITRIX_WEBHOOK_BASE=https://your-company.bitrix24.ru/rest/1/your_webhook_token/

# User ID that owns the webhook. The bot ignores messages from this user.
BITRIX_SELF_USER_ID=1

# MySQL DSN.
DB_DSN=root:secret@tcp(127.0.0.1:3306)/bitrix_auto_reply?parseTime=true&charset=utf8mb4

# Worker settings.
POLL_INTERVAL_SECONDS=5
DIALOG_COOLDOWN_SECONDS=30

# Admin UI basic auth.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change_me
